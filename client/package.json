{
  "name": "ghostspan",
  "version": "1.0.0",
  "description": "GhostSpan - Open Telemetry C2 Framework",
  "main": "src/main/main.js",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run start\" \"wait-on http://localhost:3000 && npm run electron\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run setup-go:win && npm run setup-mingw:win && npm run build && electron-builder --win",
    "dist:mac": "npm run setup-go:mac && npm run build && electron-builder --mac",
    "dist:linux": "npm run setup-go:linux && npm run build && electron-builder --linux",
    "setup-go:win": "node scripts/setup-go.js windows",
    "setup-go:mac": "node scripts/setup-go.js darwin",
    "setup-go:linux": "node scripts/setup-go.js linux",
    "setup-go:all": "node scripts/setup-go.js all",
    "setup-mingw": "node scripts/setup-mingw.js",
    "setup-mingw:win": "node scripts/setup-mingw.js windows",
    "setup-mingw:linux": "node scripts/setup-mingw.js linux",
    "setup-mingw:mac": "node scripts/setup-mingw.js darwin",
    "setup-mingw:all": "node scripts/setup-mingw.js all",
    "setup:linux": "npm run setup-go:linux && npm run setup-mingw:linux",
    "setup:mac": "npm run setup-go:mac && npm run setup-mingw:mac",
    "setup:win": "npm run setup-go:win && npm run setup-mingw:win",
    "setup:all": "npm run setup-go:all && npm run setup-mingw:all",
    "precompile": "node scripts/precompile-templates.js",
    "generate-icon": "node scripts/generate-icon.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.ghostspan.client",
    "productName": "GhostSpan",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "precompiled-templates",
        "to": "precompiled-templates",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "tar.gz"
      ],
      "icon": "public/icons",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "telemetry",
    "opentelemetry",
    "monitoring"
  ],
  "author": {
    "name": "redroot97",
    "email": "dhiyaneshselvaraj97@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "babel-loader": "^10.0.0",
    "buffer": "^6.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "html-webpack-plugin": "^5.6.5",
    "process": "^0.11.10",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "wait-on": "^7.0.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
